---
import Base from '../layouts/Base.astro';

const papers = [
  {
    title: 'On the Reasoning Gaps of Large Language Models: A Formal Characterization',
    venue: 'NeurIPS 2026',
    status: 'In Progress',
    description: 'Formally characterizing reasoning failures via computational complexity',
  },
  {
    title: 'A Taxonomy of Failure Modes in LLM-Based Autonomous Agents',
    venue: 'ACL 2027',
    status: 'In Progress',
    description: 'Comprehensive survey categorizing agent failure modes',
  },
];
---

<Base title="Papers">
  <section class="max-w-5xl mx-auto px-6 pt-24 pb-16">
    <h1 class="font-mono text-[var(--color-text-bright)]">PAPERS</h1>
    <p class="mt-4 text-lg text-[var(--color-text-secondary)] max-w-2xl">
      Publications and preprints from Deepwork Research
    </p>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-12">
    <div class="border border-[var(--color-border)] bg-[var(--color-bg-surface)] p-8">
      <p class="font-mono text-sm text-[var(--color-text-muted)]">
        Papers in progress. First submissions targeting NeurIPS 2026 and ACL 2027.
      </p>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-6 pb-24">
    <p class="label mb-8">Upcoming</p>

    <div class="flex flex-col gap-6">
      {papers.map((paper) => (
        <article class="border-t-[3px] border-t-[var(--color-text)] border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-6">
          <div class="flex flex-wrap items-center gap-4 mb-3">
            <span class="label text-[var(--color-text-secondary)]">{paper.venue}</span>
            <span class="font-mono text-xs font-medium px-2 py-0.5 border border-[var(--color-border-strong)] text-[var(--color-text-muted)] uppercase tracking-wider">
              {paper.status}
            </span>
          </div>
          <h3 class="font-mono font-semibold text-[var(--color-text-bright)] leading-snug">
            {paper.title}
          </h3>
          <p class="mt-2 text-[var(--color-text-secondary)] text-sm">
            {paper.description}
          </p>
        </article>
      ))}
    </div>
  </section>
</Base>
