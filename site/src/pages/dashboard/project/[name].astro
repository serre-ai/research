---
import Base from '../../../layouts/Base.astro';
import ProjectSubnav from '../../../components/ProjectSubnav.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import { getProjects, getEvalData, getDecisions } from '../../../data';
import { timeAgo } from '../../../utils/helpers';

export function getStaticPaths() {
  return [
    { params: { name: 'reasoning-gaps' } },
    { params: { name: 'agent-failure-taxonomy' } },
  ];
}

const { name } = Astro.params;
const allProjects = await getProjects();
const project = allProjects.find(p => p.name === name)!;
const projectEval = await getEvalData(name);
const projectDecisions = await getDecisions(name);
---

<Base title={project.title}>

  <ProjectSubnav projectName={name} activeTab="overview" />

  <!-- Project Header -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-6">
    <div class="flex items-center gap-2 mb-4">
      <a href="/dashboard" class="font-mono text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] transition-colors hover:no-underline">Dashboard</a>
      <span class="font-mono text-[10px] text-[var(--color-text-muted)]">/</span>
      <span class="font-mono text-[10px] text-[var(--color-text-secondary)]">{project.name}</span>
    </div>
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl sm:text-3xl font-mono font-bold tracking-tight text-[var(--color-text-bright)] leading-[1.1]">
          {project.title}
        </h1>
        <p class="text-sm text-[var(--color-text-muted)] mt-2 max-w-2xl">{project.description}</p>
      </div>
      <div class="flex items-center gap-3 shrink-0 ml-4">
        <span class="font-mono text-[10px] text-[var(--color-text-muted)] tracking-wider uppercase">{project.venue}</span>
        <StatusBadge status={project.status} />
      </div>
    </div>
  </section>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <!-- Phase Timeline -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">
    <p class="label mb-6">Phase Progress</p>
    <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
      <div class="flex items-center gap-2">
        {project.phases.map((phase, i) => (
          <>
            <div class:list={[
              'flex items-center gap-2 px-3 py-2 font-mono text-xs',
              phase.status === 'complete' && 'text-emerald-400 bg-emerald-500/10 border border-emerald-500/20',
              phase.status === 'active' && 'text-[var(--color-primary)] bg-[var(--color-primary-muted)] border border-[var(--color-primary)]/30 font-medium',
              phase.status === 'pending' && 'text-[var(--color-text-muted)] bg-[var(--color-bg-surface)] border border-[var(--color-border)]',
            ]}>
              {phase.status === 'complete' && <span class="text-emerald-400 text-[10px]">&#10003;</span>}
              {phase.status === 'active' && <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>}
              {phase.name}
            </div>
            {i < project.phases.length - 1 && (
              <div class:list={[
                'w-4 h-px',
                phase.status === 'complete' ? 'bg-emerald-500/40' : 'bg-[var(--color-border)]',
              ]}></div>
            )}
          </>
        ))}
      </div>
    </div>
  </section>

  <!-- Key Metrics -->
  <section class="max-w-6xl mx-auto px-6 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {projectEval ? (
        <>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Models</p>
            <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">
              {project.modelsCompleted}<span class="text-[var(--color-text-muted)] text-base font-normal">/{project.modelsTotal}</span>
            </p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">evaluated</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Combinations</p>
            <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">
              {project.tasksCompleted}<span class="text-[var(--color-text-muted)] text-base font-normal">/{project.tasksTotal}</span>
            </p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">task × model × cond</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Instances</p>
            <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">
              {projectEval.totalInstances.toLocaleString()}
            </p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">evaluated</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Completion</p>
            <p class="font-mono text-2xl font-bold text-emerald-400 tabular-nums">
              {project.completionPct}<span class="text-[var(--color-text-muted)] text-lg font-normal">%</span>
            </p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">of eval matrix</p>
          </div>
        </>
      ) : (
        <>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Phase</p>
            <p class="font-mono text-lg font-bold text-[var(--color-text-bright)]">{project.phaseNumber}<span class="text-[var(--color-text-muted)] text-sm font-normal">/{project.totalPhases}</span></p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">{project.phases.find(p => p.status === 'active')?.name}</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Venue</p>
            <p class="font-mono text-lg font-bold text-[var(--color-text-bright)]">{project.venue}</p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">target</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Decisions</p>
            <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">{projectDecisions.length}</p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">logged</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Last Activity</p>
            <p class="font-mono text-lg font-bold text-[var(--color-text-bright)]">{timeAgo(project.lastActivity)}</p>
          </div>
        </>
      )}
    </div>
  </section>

  <!-- Active Evals + Recent Decisions -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

      {/* Eval Summary or Empty State */}
      <div class="md:col-span-2 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        {projectEval ? (
          <>
            <div class="flex items-center justify-between mb-5">
              <p class="label">Evaluation Pipeline</p>
              <a href={`/dashboard/project/${name}/eval`} class="font-mono text-[10px] text-[var(--color-primary)] hover:no-underline">View details &rarr;</a>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
              <div>
                <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">
                  {project.modelsCompleted}<span class="text-[var(--color-text-muted)] text-base font-normal">/{project.modelsTotal}</span>
                </p>
                <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">Models Complete</p>
              </div>
              <div>
                <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">{projectEval.totalInstances.toLocaleString()}</p>
                <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">Instances Run</p>
              </div>
              <div>
                <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">{project.completionPct}<span class="text-[var(--color-text-muted)] text-lg font-normal">%</span></p>
                <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">Overall Progress</p>
              </div>
              <div>
                <p class="font-mono text-2xl font-bold text-emerald-400 tabular-nums">{projectEval.runningNow.length}</p>
                <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">Running Now</p>
              </div>
            </div>
            {projectEval.runningNow.length > 0 && (
              <div class="pt-4 border-t border-[var(--color-border)]">
                <p class="font-mono text-[10px] text-[var(--color-text-muted)] mb-2">ACTIVE RUNS</p>
                <div class="flex flex-wrap gap-2">
                  {projectEval.runningNow.map((model) => (
                    <span class="font-mono text-xs px-2.5 py-1 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                      {model}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <div class="text-center py-12">
            <p class="font-mono text-sm text-[var(--color-text-muted)]">No evaluation data yet</p>
            <p class="text-xs text-[var(--color-text-muted)] mt-2">This project is in the {project.phases.find(p => p.status === 'active')?.name} phase.</p>
          </div>
        )}
      </div>

      {/* Recent Decisions */}
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <div class="flex items-center justify-between mb-5">
          <p class="label">Decisions</p>
          <a href={`/dashboard/project/${name}/decisions`} class="font-mono text-[10px] text-[var(--color-primary)] hover:no-underline">All &rarr;</a>
        </div>
        {projectDecisions.length > 0 ? (
          <div class="space-y-0 divide-y divide-[var(--color-border)]">
            {projectDecisions.slice(0, 3).map((d) => (
              <div class="py-3 first:pt-0 last:pb-0">
                <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums">{d.date}</span>
                <p class="font-mono text-xs text-[var(--color-text-bright)] leading-snug mt-1">{d.decision}</p>
              </div>
            ))}
          </div>
        ) : (
          <p class="font-mono text-xs text-[var(--color-text-muted)]">No decisions logged yet.</p>
        )}
      </div>

    </div>
  </section>

</Base>
