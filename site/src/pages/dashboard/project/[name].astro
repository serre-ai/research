---
import Base from '../../../layouts/Base.astro';
import Container from '../../../components/Container.astro';
import PageHeader from '../../../components/PageHeader.astro';
import TabNav from '../../../components/TabNav.astro';
import StatusBadge from '../../../components/StatusBadge.astro';
import MetricCard from '../../../components/MetricCard.astro';
import Card from '../../../components/Card.astro';
import EmptyState from '../../../components/EmptyState.astro';
import { getProjects, getEvalData, getDecisions } from '../../../data';
import { timeAgo } from '../../../utils/helpers';

export function getStaticPaths() {
  return [
    { params: { name: 'reasoning-gaps' } },
    { params: { name: 'agent-failure-taxonomy' } },
  ];
}

const { name } = Astro.params;
const allProjects = await getProjects();
const project = allProjects.find(p => p.name === name)!;
const projectEval = await getEvalData(name);
const projectDecisions = await getDecisions(name);

const base = `/dashboard/project/${name}`;
const tabItems = [
  { href: base, key: 'overview', label: 'Overview' },
  { href: `${base}/eval`, key: 'eval', label: 'Eval' },
  { href: `${base}/budget`, key: 'budget', label: 'Budget' },
  { href: `${base}/decisions`, key: 'decisions', label: 'Decisions' },
];

const breadcrumbs = [
  { label: 'Dashboard', href: '/dashboard' },
  { label: project.name },
];
---

<Base title={project.title}>

  <TabNav items={tabItems} active="overview" />

  <!-- Project Header -->
  <PageHeader title={project.title} breadcrumbs={breadcrumbs}>
    <p class="text-sm text-[var(--color-text-muted)] mt-2 max-w-2xl">{project.description}</p>
    <div class="flex items-center gap-3 absolute top-10 right-6 shrink-0">
      <span class="stat-label">{project.venue}</span>
      <StatusBadge status={project.status} />
    </div>
  </PageHeader>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <!-- Phase Timeline -->
  <Container class="section-gap">
    <p class="label mb-6">Phase Progress</p>
    <Card>
      <div class="flex items-center gap-2">
        {project.phases.map((phase, i) => (
          <>
            <div class:list={[
              'flex items-center gap-2 px-3 py-2 font-mono text-xs',
              phase.status === 'complete' && 'text-emerald-400 bg-emerald-500/10 border border-emerald-500/20',
              phase.status === 'active' && 'text-[var(--color-primary)] bg-[var(--color-primary-muted)] border border-[var(--color-primary)]/30 font-medium',
              phase.status === 'pending' && 'text-[var(--color-text-muted)] bg-[var(--color-bg-surface)] border border-[var(--color-border)]',
            ]}>
              {phase.status === 'complete' && <span class="text-emerald-400 text-[10px]">&#10003;</span>}
              {phase.status === 'active' && <span class="w-1.5 h-1.5 rounded-full bg-[var(--color-primary)] animate-pulse"></span>}
              {phase.name}
            </div>
            {i < project.phases.length - 1 && (
              <div class:list={[
                'w-4 h-px',
                phase.status === 'complete' ? 'bg-emerald-500/40' : 'bg-[var(--color-border)]',
              ]}></div>
            )}
          </>
        ))}
      </div>
    </Card>
  </Container>

  <!-- Key Metrics -->
  <Container class="pb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      {projectEval ? (
        <>
          <MetricCard label="Models" icon="cpu">
            <span slot="value">
              {project.modelsCompleted}<span class="text-[var(--color-text-muted)] text-base font-normal">/{project.modelsTotal}</span>
            </span>
          </MetricCard>
          <MetricCard label="Combinations" icon="bar-chart-3">
            <span slot="value">
              {project.tasksCompleted}<span class="text-[var(--color-text-muted)] text-base font-normal">/{project.tasksTotal}</span>
            </span>
          </MetricCard>
          <MetricCard label="Instances" value={projectEval.totalInstances.toLocaleString()} sublabel="evaluated" icon="activity" />
          <MetricCard label="Completion" color="text-emerald-400" icon="check-circle">
            <span slot="value">
              {project.completionPct}<span class="text-[var(--color-text-muted)] text-lg font-normal">%</span>
            </span>
          </MetricCard>
        </>
      ) : (
        <>
          <MetricCard label="Phase" icon="git-commit">
            <span slot="value">
              {project.phaseNumber}<span class="text-[var(--color-text-muted)] text-sm font-normal">/{project.totalPhases}</span>
            </span>
          </MetricCard>
          <MetricCard label="Venue" value={project.venue} sublabel="target" icon="file-text" />
          <MetricCard label="Decisions" value={projectDecisions.length} sublabel="logged" icon="brain" />
          <MetricCard label="Last Activity" value={timeAgo(project.lastActivity)} icon="clock" />
        </>
      )}
    </div>
  </Container>

  <!-- Active Evals + Recent Decisions -->
  <Container class="pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

      {/* Eval Summary or Empty State */}
      <Card class="md:col-span-2">
        {projectEval ? (
          <>
            <div class="flex items-center justify-between mb-5">
              <p class="label">Evaluation Pipeline</p>
              <a href={`/dashboard/project/${name}/eval`} class="font-mono text-[10px] text-[var(--color-primary)] hover:no-underline">View details &rarr;</a>
            </div>
            <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5">
              <div>
                <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">
                  {project.modelsCompleted}<span class="text-[var(--color-text-muted)] text-base font-normal">/{project.modelsTotal}</span>
                </p>
                <p class="stat-label mt-1">Models Complete</p>
              </div>
              <div>
                <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">{projectEval.totalInstances.toLocaleString()}</p>
                <p class="stat-label mt-1">Instances Run</p>
              </div>
              <div>
                <p class="font-mono text-2xl font-bold text-[var(--color-text-bright)] tabular-nums">{project.completionPct}<span class="text-[var(--color-text-muted)] text-lg font-normal">%</span></p>
                <p class="stat-label mt-1">Overall Progress</p>
              </div>
              <div>
                <p class="font-mono text-2xl font-bold text-emerald-400 tabular-nums">{projectEval.runningNow.length}</p>
                <p class="stat-label mt-1">Running Now</p>
              </div>
            </div>
            {projectEval.runningNow.length > 0 && (
              <div class="pt-4 border-t border-[var(--color-border)]">
                <p class="stat-label mb-2">ACTIVE RUNS</p>
                <div class="flex flex-wrap gap-2">
                  {projectEval.runningNow.map((model) => (
                    <span class="font-mono text-xs px-2.5 py-1 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20">
                      {model}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </>
        ) : (
          <EmptyState message="No evaluation data yet" detail={`This project is in the ${project.phases.find(p => p.status === 'active')?.name} phase.`} icon="beaker" />
        )}
      </Card>

      {/* Recent Decisions */}
      <Card>
        <div class="flex items-center justify-between mb-5">
          <p class="label">Decisions</p>
          <a href={`/dashboard/project/${name}/decisions`} class="font-mono text-[10px] text-[var(--color-primary)] hover:no-underline">All &rarr;</a>
        </div>
        {projectDecisions.length > 0 ? (
          <div class="space-y-0 divide-y divide-[var(--color-border)]">
            {projectDecisions.slice(0, 3).map((d) => (
              <div class="py-3 first:pt-0 last:pb-0">
                <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums">{d.date}</span>
                <p class="font-mono text-xs text-[var(--color-text-bright)] leading-snug mt-1">{d.decision}</p>
              </div>
            ))}
          </div>
        ) : (
          <p class="font-mono text-xs text-[var(--color-text-muted)]">No decisions logged yet.</p>
        )}
      </Card>

    </div>
  </Container>

</Base>
