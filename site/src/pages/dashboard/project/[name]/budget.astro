---
import Base from '../../../../layouts/Base.astro';
import ProjectSubnav from '../../../../components/ProjectSubnav.astro';
import { getProjects, getBudgetData } from '../../../../data';
import { barWidth, spendColor, spendTextColor } from '../../../../utils/helpers';

export function getStaticPaths() {
  return [
    { params: { name: 'reasoning-gaps' } },
    { params: { name: 'agent-failure-taxonomy' } },
  ];
}

const allProjects = await getProjects();
const { name } = Astro.params;
const project = allProjects.find(p => p.name === name)!;
const budget = await getBudgetData(name);

const hasData = budget && budget.providers.length > 0;
const totalSpent = hasData ? budget.providers.reduce((sum, p) => sum + p.spent, 0) : 0;
const remaining = (budget?.monthlyLimit ?? 1000) - totalSpent;
const daysInMonth = 31;
const dayOfMonth = 11;
const daysRemaining = daysInMonth - dayOfMonth;
const dailyBurnRate = dayOfMonth > 0 ? totalSpent / dayOfMonth : 0;
const projectedMonthly = dailyBurnRate * daysInMonth;
const onTrack = projectedMonthly <= (budget?.monthlyLimit ?? 1000);
const maxDailySpend = hasData ? Math.max(...budget.dailySpend.map(d => d.amount), 1) : 1;
---

<Base title={`${project.title} — Budget`}>

  <ProjectSubnav projectName={name} activeTab="budget" />

  <section class="max-w-6xl mx-auto px-6 pt-10 pb-6">
    <div class="flex items-center gap-2 mb-4">
      <a href="/dashboard" class="font-mono text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] transition-colors hover:no-underline">Dashboard</a>
      <span class="font-mono text-[10px] text-[var(--color-text-muted)]">/</span>
      <a href={`/dashboard/project/${name}`} class="font-mono text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] transition-colors hover:no-underline">{project.name}</a>
      <span class="font-mono text-[10px] text-[var(--color-text-muted)]">/</span>
      <span class="font-mono text-[10px] text-[var(--color-text-secondary)]">Budget</span>
    </div>
    <h1 class="text-2xl sm:text-3xl font-mono font-bold tracking-tight text-[var(--color-text-bright)] leading-[1.1]">
      BUDGET TRACKER
    </h1>
    <p class="text-sm text-[var(--color-text-muted)] mt-2">
      March 2026 &mdash; Day {dayOfMonth} of {daysInMonth}
    </p>
  </section>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  {!hasData ? (
    <section class="max-w-6xl mx-auto px-6 py-20 text-center">
      <p class="font-mono text-sm text-[var(--color-text-muted)]">No budget data available.</p>
      <p class="text-xs text-[var(--color-text-muted)] mt-2">This project hasn't incurred any costs yet.</p>
    </section>
  ) : (
    <>
      {/* KPIs */}
      <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Total Spent</p>
            <p class="font-mono text-3xl font-bold text-[var(--color-text-bright)] tabular-nums">${totalSpent.toFixed(2)}</p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">of ${budget.monthlyLimit} limit</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Remaining</p>
            <p class="font-mono text-3xl font-bold text-emerald-400 tabular-nums">${remaining.toFixed(2)}</p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">{daysRemaining} days left</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Daily Burn Rate</p>
            <p class="font-mono text-3xl font-bold text-[var(--color-text-bright)] tabular-nums">${dailyBurnRate.toFixed(2)}</p>
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">avg/day (limit: ${budget.dailyLimit})</p>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Projected Monthly</p>
            <p class={`font-mono text-3xl font-bold tabular-nums ${onTrack ? 'text-emerald-400' : 'text-red-400'}`}>${projectedMonthly.toFixed(0)}</p>
            <p class={`font-mono text-[10px] mt-1 ${onTrack ? 'text-emerald-400' : 'text-red-400'}`}>{onTrack ? 'ON TRACK' : 'OVER BUDGET'}</p>
          </div>
        </div>
      </section>

      {/* Monthly Progress */}
      <section class="max-w-6xl mx-auto px-6 pb-8">
        <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
          <div class="flex justify-between items-center mb-3">
            <p class="label">Monthly Budget Usage</p>
            <span class="font-mono text-xs text-[var(--color-text-secondary)] tabular-nums">
              {((totalSpent / budget.monthlyLimit) * 100).toFixed(1)}% used
            </span>
          </div>
          <div class="h-3 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden relative">
            <div class={`h-full ${spendColor(totalSpent, budget.monthlyLimit)} transition-all`} style={`width: ${(totalSpent / budget.monthlyLimit) * 100}%`}></div>
            <div class="absolute top-0 bottom-0 w-px bg-[var(--color-text-muted)]" style={`left: ${(dayOfMonth / daysInMonth) * 100}%`} title="Today"></div>
          </div>
          <div class="flex justify-between mt-2 font-mono text-[9px] text-[var(--color-text-muted)]">
            <span>$0</span>
            <span class="tabular-nums">${budget.monthlyLimit.toLocaleString()}</span>
          </div>
        </div>
      </section>

      {/* Provider Breakdown + Daily Spend */}
      <section class="max-w-6xl mx-auto px-6 pb-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">
          <div class="lg:col-span-2 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="label mb-5">Spend by Provider</p>
            <div class="space-y-5">
              {budget.providers.map((provider) => (
                <div>
                  <div class="flex items-center justify-between mb-2">
                    <span class="font-mono text-sm font-semibold text-[var(--color-text-bright)]">{provider.name}</span>
                    <div class="flex items-center gap-3">
                      <span class={`font-mono text-sm font-semibold tabular-nums ${spendTextColor(provider.spent, provider.limit)}`}>${provider.spent.toFixed(2)}</span>
                      <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums">/ ${provider.limit}</span>
                    </div>
                  </div>
                  <div class="h-2 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden">
                    <div class={`h-full transition-all ${spendColor(provider.spent, provider.limit)}`} style={`width: ${barWidth(provider.spent, provider.limit)}%`}></div>
                  </div>
                </div>
              ))}
            </div>
          </div>
          <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
            <p class="label mb-5">Daily Spend (Last 7d)</p>
            <div class="flex items-end gap-1.5 h-32">
              {budget.dailySpend.map((day) => {
                const height = (day.amount / maxDailySpend) * 100;
                const overLimit = day.amount > budget.dailyLimit;
                return (
                  <div class="flex-1 flex flex-col items-center gap-1">
                    <span class="font-mono text-[9px] text-[var(--color-text-muted)] tabular-nums">${day.amount.toFixed(0)}</span>
                    <div class="w-full relative" style={`height: ${height}%`}>
                      <div class={`absolute inset-0 ${overLimit ? 'bg-red-500/40' : 'bg-emerald-500/30'} border-t-2 ${overLimit ? 'border-red-500/60' : 'border-emerald-500/50'}`}></div>
                    </div>
                    <span class="font-mono text-[8px] text-[var(--color-text-muted)]">{day.date}</span>
                  </div>
                );
              })}
            </div>
            <div class="mt-3 pt-2 border-t border-[var(--color-border)] flex items-center gap-2">
              <div class="flex-1 h-px" style="border-top: 1px dashed rgba(245, 158, 11, 0.4);"></div>
              <span class="font-mono text-[9px] text-amber-400 tabular-nums">${budget.dailyLimit}/day limit</span>
            </div>
          </div>
        </div>
      </section>

      {/* Per-Model Cost Breakdown */}
      <section class="max-w-6xl mx-auto px-6 pb-20">
        <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] overflow-x-auto">
          <div class="p-5 pb-0">
            <p class="label mb-5">Per-Model Cost Breakdown</p>
          </div>
          <table class="w-full border-collapse">
            <thead>
              <tr class="border-b border-[var(--color-border)] border-t border-t-[var(--color-border)]">
                <th class="text-left font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Model</th>
                <th class="text-left font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Provider</th>
                <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">API Calls</th>
                <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Tokens</th>
                <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Cost</th>
                <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3 min-w-[120px]">Share</th>
              </tr>
            </thead>
            <tbody>
              {budget.providers.flatMap((provider) =>
                provider.models.map((model) => {
                  const pct = totalSpent > 0 ? (model.cost / totalSpent) * 100 : 0;
                  return (
                    <tr class="border-b border-[var(--color-border)] hover:bg-white/[0.02] transition-colors">
                      <td class="p-3"><span class="font-mono text-xs text-[var(--color-text-bright)]">{model.name}</span></td>
                      <td class="p-3"><span class="font-mono text-xs text-[var(--color-text-muted)]">{provider.name}</span></td>
                      <td class="p-3 text-right"><span class="font-mono text-xs text-[var(--color-text-secondary)] tabular-nums">{model.calls.toLocaleString()}</span></td>
                      <td class="p-3 text-right"><span class="font-mono text-xs text-[var(--color-text-secondary)] tabular-nums">{model.tokens}</span></td>
                      <td class="p-3 text-right"><span class="font-mono text-xs text-[var(--color-text-bright)] font-medium tabular-nums">${model.cost.toFixed(2)}</span></td>
                      <td class="p-3">
                        <div class="flex items-center gap-2">
                          <div class="flex-1 h-1.5 bg-[var(--color-bg-surface)] overflow-hidden">
                            <div class="h-full bg-[var(--color-text-muted)]/30" style={`width: ${pct}%`}></div>
                          </div>
                          <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums w-8 text-right">{pct.toFixed(0)}%</span>
                        </div>
                      </td>
                    </tr>
                  );
                })
              )}
            </tbody>
            <tfoot>
              <tr class="border-t-2 border-[var(--color-border-strong)]">
                <td colspan="4" class="p-3"><span class="font-mono text-xs font-semibold text-[var(--color-text-bright)]">TOTAL</span></td>
                <td class="p-3 text-right"><span class="font-mono text-xs font-bold text-[var(--color-text-bright)] tabular-nums">${totalSpent.toFixed(2)}</span></td>
                <td class="p-3"><span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums">100%</span></td>
              </tr>
            </tfoot>
          </table>
        </div>
      </section>
    </>
  )}

</Base>
