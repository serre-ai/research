---
import Base from '../../../../layouts/Base.astro';
import Container from '../../../../components/Container.astro';
import PageHeader from '../../../../components/PageHeader.astro';
import TabNav from '../../../../components/TabNav.astro';
import Card from '../../../../components/Card.astro';
import DecisionItem from '../../../../components/DecisionItem.astro';
import EmptyState from '../../../../components/EmptyState.astro';
import { getProjects, getDecisions } from '../../../../data';

export function getStaticPaths() {
  return [
    { params: { name: 'reasoning-gaps' } },
    { params: { name: 'agent-failure-taxonomy' } },
  ];
}

const allProjects = await getProjects();
const { name } = Astro.params;
const project = allProjects.find(p => p.name === name)!;
const projectDecisions = await getDecisions(name);

const base = `/dashboard/project/${name}`;
const tabItems = [
  { href: base, key: 'overview', label: 'Overview' },
  { href: `${base}/eval`, key: 'eval', label: 'Eval' },
  { href: `${base}/budget`, key: 'budget', label: 'Budget' },
  { href: `${base}/decisions`, key: 'decisions', label: 'Decisions' },
];

const breadcrumbs = [
  { label: 'Dashboard', href: '/dashboard' },
  { label: project.name, href: `/dashboard/project/${name}` },
  { label: 'Decisions' },
];
---

<Base title={`${project.title} — Decisions`}>

  <TabNav items={tabItems} active="decisions" />

  <PageHeader
    title="DECISION LOG"
    subtitle={`${projectDecisions.length} autonomous decisions logged for ${project.name}`}
    breadcrumbs={breadcrumbs}
  />

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <Container class="section-gap pb-20">
    {projectDecisions.length === 0 ? (
      <EmptyState message="No decisions logged yet." icon="brain" />
    ) : (
      <Card>
        <div class="space-y-0 divide-y divide-[var(--color-border)]">
          {projectDecisions.map((d) => (
            <DecisionItem
              date={d.date}
              decision={d.decision}
              rationale={d.rationale}
            />
          ))}
        </div>
      </Card>
    )}
  </Container>

</Base>
