---
// TODO: Replace mock data with API calls to /api/budget
import Base from '../../layouts/Base.astro';

const monthlyLimit = 1000;
const dailyLimit = 40;

const providers = [
  {
    name: 'Anthropic',
    spent: 15.42,
    limit: 200,
    models: [
      { name: 'claude-3-5-haiku', calls: 2700, tokens: '8.1M', cost: 12.30 },
      { name: 'claude-3-5-sonnet', calls: 0, tokens: '0', cost: 0 },
    ],
  },
  {
    name: 'OpenAI',
    spent: 59.80,
    limit: 60,
    models: [
      { name: 'gpt-4o-mini', calls: 1800, tokens: '5.4M', cost: 8.60 },
      { name: 'gpt-4o', calls: 120, tokens: '1.2M', cost: 51.20 },
    ],
  },
  {
    name: 'OpenRouter',
    spent: 0.22,
    limit: 50,
    models: [
      { name: 'llama-3-8b', calls: 45, tokens: '0.1M', cost: 0.12 },
      { name: 'llama-3-70b', calls: 12, tokens: '0.04M', cost: 0.10 },
    ],
  },
];

const totalSpent = providers.reduce((sum, p) => sum + p.spent, 0);
const remaining = monthlyLimit - totalSpent;
const daysInMonth = 31;
const dayOfMonth = 11;
const daysRemaining = daysInMonth - dayOfMonth;
const dailyBurnRate = totalSpent / dayOfMonth;
const projectedMonthly = dailyBurnRate * daysInMonth;
const onTrack = projectedMonthly <= monthlyLimit;

const dailySpend = [
  { date: '03-05', amount: 4.20 },
  { date: '03-06', amount: 6.80 },
  { date: '03-07', amount: 8.10 },
  { date: '03-08', amount: 12.50 },
  { date: '03-09', amount: 9.30 },
  { date: '03-10', amount: 22.40 },
  { date: '03-11', amount: 12.14 },
];

const maxDailySpend = Math.max(...dailySpend.map(d => d.amount));

function barWidth(value: number, max: number): number {
  return Math.min(100, (value / max) * 100);
}

function spendColor(spent: number, limit: number): string {
  const pct = (spent / limit) * 100;
  if (pct >= 90) return 'bg-red-500/60';
  if (pct >= 70) return 'bg-amber-500/50';
  return 'bg-emerald-500/50';
}

function spendTextColor(spent: number, limit: number): string {
  const pct = (spent / limit) * 100;
  if (pct >= 90) return 'text-red-400';
  if (pct >= 70) return 'text-amber-400';
  return 'text-emerald-400';
}
---

<Base title="Budget Tracker">

  <section class="max-w-6xl mx-auto px-6 pt-16 pb-6">
    <div class="flex items-end justify-between mb-2">
      <div>
        <p class="label mb-2">Dashboard</p>
        <h1 class="text-3xl sm:text-4xl font-mono font-bold tracking-tight text-[var(--color-text-bright)] leading-[1.1]">
          BUDGET TRACKER
        </h1>
      </div>
      <div class="flex items-center gap-3">
        <div class="flex gap-4 font-mono text-xs text-[var(--color-text-muted)]">
          <a href="/dashboard" class="hover:text-[var(--color-text-bright)] transition-colors hover:no-underline">Overview</a>
          <a href="/dashboard/eval" class="hover:text-[var(--color-text-bright)] transition-colors hover:no-underline">Eval</a>
          <a href="/dashboard/budget" class="text-[var(--color-text-bright)] hover:no-underline">Budget</a>
        </div>
      </div>
    </div>
    <p class="text-sm text-[var(--color-text-muted)] mt-3">
      March 2026 &mdash; Day {dayOfMonth} of {daysInMonth}
    </p>
  </section>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <!-- Top-level KPIs -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Total Spent</p>
        <p class="font-mono text-3xl font-bold text-[var(--color-text-bright)] tabular-nums">
          ${totalSpent.toFixed(2)}
        </p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">
          of ${monthlyLimit} limit
        </p>
      </div>
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Remaining</p>
        <p class="font-mono text-3xl font-bold text-emerald-400 tabular-nums">
          ${remaining.toFixed(2)}
        </p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">
          {daysRemaining} days left
        </p>
      </div>
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Daily Burn Rate</p>
        <p class="font-mono text-3xl font-bold text-[var(--color-text-bright)] tabular-nums">
          ${dailyBurnRate.toFixed(2)}
        </p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">
          avg/day (limit: ${dailyLimit})
        </p>
      </div>
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Projected Monthly</p>
        <p class={`font-mono text-3xl font-bold tabular-nums ${onTrack ? 'text-emerald-400' : 'text-red-400'}`}>
          ${projectedMonthly.toFixed(0)}
        </p>
        <p class={`font-mono text-[10px] mt-1 ${onTrack ? 'text-emerald-400' : 'text-red-400'}`}>
          {onTrack ? 'ON TRACK' : 'OVER BUDGET'}
        </p>
      </div>
    </div>
  </section>

  <!-- Monthly Progress Bar -->
  <section class="max-w-6xl mx-auto px-6 pb-8">
    <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
      <div class="flex justify-between items-center mb-3">
        <p class="label">Monthly Budget Usage</p>
        <span class="font-mono text-xs text-[var(--color-text-secondary)] tabular-nums">
          {((totalSpent / monthlyLimit) * 100).toFixed(1)}% used
        </span>
      </div>
      <div class="h-3 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden relative">
        <div class={`h-full ${spendColor(totalSpent, monthlyLimit)} transition-all`} style={`width: ${(totalSpent / monthlyLimit) * 100}%`}></div>
        <!-- Day marker -->
        <div class="absolute top-0 bottom-0 w-px bg-[var(--color-text-muted)]" style={`left: ${(dayOfMonth / daysInMonth) * 100}%`} title="Today"></div>
      </div>
      <div class="flex justify-between mt-2 font-mono text-[9px] text-[var(--color-text-muted)]">
        <span>$0</span>
        <span class="tabular-nums">${monthlyLimit.toLocaleString()}</span>
      </div>
    </div>
  </section>

  <!-- Provider Breakdown + Daily Spend -->
  <section class="max-w-6xl mx-auto px-6 pb-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-5">

      <!-- Provider Spend -->
      <div class="lg:col-span-2 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="label mb-5">Spend by Provider</p>
        <div class="space-y-5">
          {providers.map((provider) => (
            <div>
              <div class="flex items-center justify-between mb-2">
                <span class="font-mono text-sm font-semibold text-[var(--color-text-bright)]">{provider.name}</span>
                <div class="flex items-center gap-3">
                  <span class={`font-mono text-sm font-semibold tabular-nums ${spendTextColor(provider.spent, provider.limit)}`}>
                    ${provider.spent.toFixed(2)}
                  </span>
                  <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums">
                    / ${provider.limit}
                  </span>
                </div>
              </div>
              <div class="h-2 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden">
                <div class={`h-full transition-all ${spendColor(provider.spent, provider.limit)}`}
                  style={`width: ${barWidth(provider.spent, provider.limit)}%`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Daily Spend Chart -->
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="label mb-5">Daily Spend (Last 7d)</p>
        <div class="flex items-end gap-1.5 h-32">
          {dailySpend.map((day) => {
            const height = (day.amount / maxDailySpend) * 100;
            const overLimit = day.amount > dailyLimit;
            return (
              <div class="flex-1 flex flex-col items-center gap-1">
                <span class="font-mono text-[9px] text-[var(--color-text-muted)] tabular-nums">
                  ${day.amount.toFixed(0)}
                </span>
                <div class="w-full relative" style={`height: ${height}%`}>
                  <div class={`absolute inset-0 ${overLimit ? 'bg-red-500/40' : 'bg-emerald-500/30'} border-t-2 ${overLimit ? 'border-red-500/60' : 'border-emerald-500/50'}`}></div>
                </div>
                <span class="font-mono text-[8px] text-[var(--color-text-muted)]">{day.date}</span>
              </div>
            );
          })}
        </div>
        <div class="mt-3 pt-2 border-t border-[var(--color-border)] flex items-center gap-2">
          <div class="flex-1 h-px bg-amber-500/40" style="border-top: 1px dashed rgba(245, 158, 11, 0.4);"></div>
          <span class="font-mono text-[9px] text-amber-400 tabular-nums">${dailyLimit}/day limit</span>
        </div>
      </div>

    </div>
  </section>

  <!-- Per-Model Cost Breakdown -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] overflow-x-auto">
      <div class="p-5 pb-0">
        <p class="label mb-5">Per-Model Cost Breakdown</p>
      </div>
      <table class="w-full border-collapse">
        <thead>
          <tr class="border-b border-[var(--color-border)] border-t border-t-[var(--color-border)]">
            <th class="text-left font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Model</th>
            <th class="text-left font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Provider</th>
            <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">API Calls</th>
            <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Tokens</th>
            <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3">Cost</th>
            <th class="text-right font-mono text-[10px] font-medium text-[var(--color-text-muted)] uppercase tracking-wider p-3 min-w-[120px]">Share</th>
          </tr>
        </thead>
        <tbody>
          {providers.flatMap((provider) =>
            provider.models.map((model, i) => {
              const pct = totalSpent > 0 ? (model.cost / totalSpent) * 100 : 0;
              return (
                <tr class="border-b border-[var(--color-border)] hover:bg-white/[0.02] transition-colors">
                  <td class="p-3">
                    <span class="font-mono text-xs text-[var(--color-text-bright)]">{model.name}</span>
                  </td>
                  <td class="p-3">
                    <span class="font-mono text-xs text-[var(--color-text-muted)]">{provider.name}</span>
                  </td>
                  <td class="p-3 text-right">
                    <span class="font-mono text-xs text-[var(--color-text-secondary)] tabular-nums">{model.calls.toLocaleString()}</span>
                  </td>
                  <td class="p-3 text-right">
                    <span class="font-mono text-xs text-[var(--color-text-secondary)] tabular-nums">{model.tokens}</span>
                  </td>
                  <td class="p-3 text-right">
                    <span class="font-mono text-xs text-[var(--color-text-bright)] font-medium tabular-nums">${model.cost.toFixed(2)}</span>
                  </td>
                  <td class="p-3">
                    <div class="flex items-center gap-2">
                      <div class="flex-1 h-1.5 bg-[var(--color-bg-surface)] overflow-hidden">
                        <div class="h-full bg-[var(--color-text-muted)]/30" style={`width: ${pct}%`}></div>
                      </div>
                      <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums w-8 text-right">{pct.toFixed(0)}%</span>
                    </div>
                  </td>
                </tr>
              );
            })
          )}
        </tbody>
        <tfoot>
          <tr class="border-t-2 border-[var(--color-border-strong)]">
            <td colspan="4" class="p-3">
              <span class="font-mono text-xs font-semibold text-[var(--color-text-bright)]">TOTAL</span>
            </td>
            <td class="p-3 text-right">
              <span class="font-mono text-xs font-bold text-[var(--color-text-bright)] tabular-nums">${totalSpent.toFixed(2)}</span>
            </td>
            <td class="p-3">
              <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums">100%</span>
            </td>
          </tr>
        </tfoot>
      </table>
    </div>
  </section>

</Base>
