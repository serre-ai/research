---
import Base from '../../layouts/Base.astro';
import StatusBadge from '../../components/StatusBadge.astro';
import { getProjects, getDecisions, getAggregateStats, getSystemHealth } from '../../data';
import { timeAgo, healthColor, healthDot } from '../../utils/helpers';

const projects = await getProjects();
const decisions = await getDecisions();
const aggregateStats = await getAggregateStats();
const systemHealth = await getSystemHealth();
---

<Base title="Dashboard">

  <section class="max-w-6xl mx-auto px-6 pt-16 pb-6">
    <p class="label mb-2">Dashboard</p>
    <h1 class="text-3xl sm:text-4xl font-mono font-bold tracking-tight text-[var(--color-text-bright)] leading-[1.1]">
      PORTFOLIO
    </h1>
    <p class="font-mono text-xs text-[var(--color-text-muted)] tabular-nums mt-3">
      {projects.length} projects &middot; ${aggregateStats.monthlySpend.toFixed(0)} / ${aggregateStats.monthlyBudget} this month
    </p>
  </section>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <!-- Aggregate Stats -->
  <section class="max-w-6xl mx-auto px-6 pt-10 pb-8">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Projects</p>
        <p class="font-mono text-3xl font-bold text-[var(--color-text-bright)] tabular-nums">{aggregateStats.totalProjects}</p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">{projects.filter(p => p.status === 'running').length} active</p>
      </div>
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Active Sessions</p>
        <p class="font-mono text-3xl font-bold text-emerald-400 tabular-nums">{aggregateStats.activeSessions}</p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">agent processes</p>
      </div>
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Papers in Pipeline</p>
        <p class="font-mono text-3xl font-bold text-[var(--color-text-bright)] tabular-nums">{aggregateStats.papersInPipeline}</p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1">targeting venues</p>
      </div>
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] uppercase tracking-wider mb-2">Monthly Spend</p>
        <p class="font-mono text-3xl font-bold text-emerald-400 tabular-nums">${aggregateStats.monthlySpend.toFixed(0)}</p>
        <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-1 tabular-nums">of ${aggregateStats.monthlyBudget} budget</p>
      </div>
    </div>
  </section>

  <!-- Project Cards -->
  <section class="max-w-6xl mx-auto px-6 pb-8">
    <p class="label mb-6">Projects</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {projects.map((p) => (
        <a href={`/dashboard/project/${p.name}`} class="block hover:no-underline group">
          <article class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] relative overflow-hidden transition-colors group-hover:border-[var(--color-border-strong)]">
            <div class="absolute top-0 left-0 right-0 h-[2px]" style={`background: ${p.status === 'running' ? '#10b981' : '#f59e0b'}`}></div>
            <div class="p-5">
              <div class="flex items-start justify-between mb-4">
                <div>
                  <p class="font-mono text-[10px] text-[var(--color-text-muted)] tracking-wider uppercase mb-1">{p.venue}</p>
                  <h3 class="font-mono text-base font-semibold text-[var(--color-text-bright)] leading-snug">{p.title}</h3>
                </div>
                <StatusBadge status={p.status} />
              </div>
              <p class="font-mono text-xs text-[var(--color-text-secondary)] mb-4">{p.phase}</p>
              {p.completionPct > 0 ? (
                <div>
                  <div class="flex justify-between font-mono text-xs mb-1.5">
                    <span class="text-[var(--color-text-muted)]">Eval progress</span>
                    <span class="text-[var(--color-text-secondary)] tabular-nums">{p.completionPct}%</span>
                  </div>
                  <div class="h-1.5 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden">
                    <div class="h-full bg-emerald-500/60 transition-all" style={`width: ${p.completionPct}%`}></div>
                  </div>
                  <div class="flex gap-6 mt-3 font-mono text-[10px] text-[var(--color-text-muted)]">
                    <span><span class="text-[var(--color-text-secondary)] tabular-nums">{p.modelsCompleted}</span>/{p.modelsTotal} models</span>
                    <span><span class="text-[var(--color-text-secondary)] tabular-nums">{p.tasksCompleted}</span>/{p.tasksTotal} combos</span>
                  </div>
                </div>
              ) : (
                <p class="font-mono text-[10px] text-[var(--color-text-muted)]">No active evaluations</p>
              )}
              <div class="mt-4 pt-3 border-t border-[var(--color-border)] flex justify-between items-center">
                <span class="font-mono text-[10px] text-[var(--color-text-muted)]">
                  Last activity: {timeAgo(p.lastActivity)}
                </span>
                <span class="font-mono text-[10px] text-[var(--color-text-muted)]">
                  {p.name}
                </span>
              </div>
            </div>
          </article>
        </a>
      ))}
    </div>
  </section>

  <!-- System Health + Recent Decisions -->
  <section class="max-w-6xl mx-auto px-6 pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

      <!-- Recent Decisions -->
      <div class="md:col-span-2 border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="label mb-5">Recent Decisions</p>
        <div class="space-y-0 divide-y divide-[var(--color-border)]">
          {decisions.slice(0, 5).map((d) => (
            <div class="py-3 first:pt-0 last:pb-0">
              <div class="flex items-start gap-4">
                <div class="shrink-0 pt-0.5">
                  <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums whitespace-nowrap">{d.date}</span>
                </div>
                <div class="min-w-0 flex-1">
                  <div class="flex items-center gap-2 mb-0.5">
                    <a href={`/dashboard/project/${d.project}`} class="font-mono text-[10px] px-1.5 py-0 bg-[var(--color-bg-surface)] text-[var(--color-text-muted)] border border-[var(--color-border)] hover:text-[var(--color-text-secondary)] hover:no-underline transition-colors">
                      {d.project}
                    </a>
                  </div>
                  <p class="font-mono text-sm text-[var(--color-text-bright)] leading-snug">{d.decision}</p>
                  <p class="text-xs text-[var(--color-text-muted)] mt-1 leading-relaxed">{d.rationale}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- System Health -->
      <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
        <p class="label mb-5">System Health</p>
        <div class="space-y-3">
          {Object.entries(systemHealth).map(([key, value]) => (
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class={`w-1.5 h-1.5 rounded-full ${healthDot(value)}`}></div>
                <span class="font-mono text-xs text-[var(--color-text-secondary)]">
                  {key.replace(/([A-Z])/g, ' $1').replace(/^./, s => s.toUpperCase()).replace('Api', 'API')}
                </span>
              </div>
              <span class={`font-mono text-[10px] ${healthColor(value)}`}>
                {value}
              </span>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>

</Base>
