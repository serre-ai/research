---
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import PageHeader from '../../components/PageHeader.astro';
import MetricCard from '../../components/MetricCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import Card from '../../components/Card.astro';
import DecisionItem from '../../components/DecisionItem.astro';
import StatusDot from '../../components/StatusDot.astro';
import { getProjects, getDecisions, getAggregateStats, getSystemHealth } from '../../data';
import { healthColor } from '../../utils/helpers';

const projects = await getProjects();
const decisions = await getDecisions();
const aggregateStats = await getAggregateStats();
const systemHealth = await getSystemHealth();
---

<Base title="Dashboard">

  <PageHeader title="PORTFOLIO">
    <p class="font-mono text-xs text-[var(--color-text-muted)] tabular-nums mt-3">
      {projects.length} projects &middot; ${aggregateStats.monthlySpend.toFixed(0)} / ${aggregateStats.monthlyBudget} this month
    </p>
  </PageHeader>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <!-- Aggregate Stats -->
  <Container class="section-gap">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-5">
      <MetricCard
        label="Projects"
        value={aggregateStats.totalProjects}
        sublabel={`${projects.filter(p => p.status === 'running').length} active`}
        icon="folder"
      />
      <MetricCard
        label="Active Sessions"
        value={aggregateStats.activeSessions}
        sublabel="agent processes"
        color="text-emerald-400"
        icon="activity"
      />
      <MetricCard
        label="Papers in Pipeline"
        value={aggregateStats.papersInPipeline}
        sublabel="targeting venues"
        icon="file-text"
      />
      <MetricCard
        label="Monthly Spend"
        value={`$${aggregateStats.monthlySpend.toFixed(0)}`}
        sublabel={`of $${aggregateStats.monthlyBudget} budget`}
        color="text-emerald-400"
        icon="dollar-sign"
      />
    </div>
  </Container>

  <!-- Project Cards -->
  <Container class="pb-8">
    <p class="label mb-6">Projects</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {projects.map((p) => (
        <ProjectCard
          name={p.name}
          title={p.title}
          venue={p.venue}
          status={p.status}
          phase={p.phase}
          completionPct={p.completionPct}
          modelsCompleted={p.modelsCompleted}
          modelsTotal={p.modelsTotal}
          tasksCompleted={p.tasksCompleted}
          tasksTotal={p.tasksTotal}
          lastActivity={p.lastActivity}
        />
      ))}
    </div>
  </Container>

  <!-- System Health + Recent Decisions -->
  <Container class="pb-20">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

      <!-- Recent Decisions -->
      <Card class="md:col-span-2">
        <p class="label mb-5">Recent Decisions</p>
        <div class="space-y-0 divide-y divide-[var(--color-border)]">
          {decisions.slice(0, 5).map((d) => (
            <DecisionItem
              date={d.date}
              decision={d.decision}
              rationale={d.rationale}
              project={d.project}
              projectHref={`/dashboard/project/${d.project}`}
            />
          ))}
        </div>
      </Card>

      <!-- System Health -->
      <Card>
        <p class="label mb-5">System Health</p>
        <div class="space-y-3">
          {Object.entries(systemHealth).map(([key, value]) => (
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <StatusDot status={value} />
                <span class="font-mono text-xs text-[var(--color-text-secondary)]">
                  {key.replace(/([A-Z])/g, ' $1').replace(/^./, s => s.toUpperCase()).replace('Api', 'API')}
                </span>
              </div>
              <span class={`font-mono text-[10px] ${healthColor(value)}`}>
                {value}
              </span>
            </div>
          ))}
        </div>
      </Card>

    </div>
  </Container>

</Base>
