---
import Base from '../../layouts/Base.astro';
import Container from '../../components/Container.astro';
import PageHeader from '../../components/PageHeader.astro';
import FilterBar from '../../components/FilterBar.astro';

// Empty = same-origin (site and API on same domain)
const API_BASE = import.meta.env.PUBLIC_API_URL || '';
const API_KEY = import.meta.env.PUBLIC_API_KEY || '';

const filters = [
  { key: 'all', label: 'All' },
  { key: 'sessions', label: 'Sessions' },
  { key: 'eval', label: 'Eval' },
  { key: 'git', label: 'Git' },
  { key: 'budget', label: 'Budget' },
  { key: 'system', label: 'System' },
];
---

<Base title="Live Feed">

  <PageHeader title="LIVE FEED">
    <div class="flex items-center gap-2 absolute top-10 right-6" id="conn-status">
      <div class="w-2 h-2 rounded-full bg-[var(--color-text-muted)]" id="conn-dot"></div>
      <span class="font-mono text-xs text-[var(--color-text-muted)]" id="conn-label">Connecting…</span>
    </div>
  </PageHeader>

  <hr class="max-w-6xl mx-auto border-[var(--color-border)]" />

  <!-- Filters -->
  <Container class="pt-6 pb-4">
    <FilterBar items={filters} />
  </Container>

  <!-- Event Feed -->
  <Container class="pb-20">
    <div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)]">
      <div id="feed" class="divide-y divide-[var(--color-border)] max-h-[70vh] overflow-y-auto">
        <div id="empty-state" class="p-8 text-center">
          <p class="font-mono text-sm text-[var(--color-text-muted)]">Loading activity…</p>
        </div>
      </div>
    </div>
    <p class="font-mono text-[10px] text-[var(--color-text-muted)] mt-3 tabular-nums" id="event-count"></p>
  </Container>

</Base>

<style>
  .event-row {
    animation: fadeSlide 0.2s ease-out;
  }
  @keyframes fadeSlide {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>

<script define:vars={{ API_BASE, API_KEY }}>
  const MAX_EVENTS = 200;

  // Category mapping
  const TYPE_CATEGORY = {
    session_start: 'sessions', session_end: 'sessions', session_error: 'sessions',
    commit: 'git', push: 'git', pr_created: 'git', pr_merged: 'git',
    decision_created: 'system', decision_resolved: 'system',
    budget_spend: 'budget', budget_alert: 'budget',
    experiment_start: 'eval', experiment_end: 'eval',
    eval_job_queued: 'eval', eval_job_started: 'eval', eval_job_completed: 'eval', eval_job_failed: 'eval',
    phase_transition: 'system',
    daemon_start: 'system', daemon_stop: 'system', daemon_error: 'system',
  };

  // Color dots per category
  const CATEGORY_COLORS = {
    sessions: 'bg-emerald-400',
    eval: 'bg-blue-400',
    git: 'bg-purple-400',
    budget: 'bg-amber-400',
    system: 'bg-[var(--color-text-muted)]',
  };

  // Error types get red dot override
  const ERROR_TYPES = new Set(['session_error', 'daemon_error', 'eval_job_failed', 'budget_alert']);

  let activeFilter = 'all';
  let events = [];

  const feed = document.getElementById('feed');
  const emptyState = document.getElementById('empty-state');
  const connDot = document.getElementById('conn-dot');
  const connLabel = document.getElementById('conn-label');
  const eventCount = document.getElementById('event-count');

  // ---- Filters ----
  document.getElementById('filters').addEventListener('click', (e) => {
    const btn = e.target.closest('.filter-btn');
    if (!btn) return;
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeFilter = btn.dataset.filter;
    renderAll();
  });

  // ---- Rendering ----
  function formatTime(ts) {
    const d = new Date(ts);
    const now = new Date();
    const diffMs = now - d;
    if (diffMs < 60000) return Math.floor(diffMs / 1000) + 's ago';
    if (diffMs < 3600000) return Math.floor(diffMs / 60000) + 'm ago';
    if (diffMs < 86400000) return Math.floor(diffMs / 3600000) + 'h ago';
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function formatType(type) {
    return type.replace(/_/g, ' ');
  }

  function summarize(ev) {
    const d = ev.data || {};
    switch (ev.type) {
      case 'session_start': return `${ev.agent || 'agent'} session started` + (d.phase ? ` (${d.phase})` : '');
      case 'session_end': return `${ev.agent || 'agent'} session ended` + (d.status ? ` — ${d.status}` : '');
      case 'session_error': return d.error || 'session error';
      case 'commit': return d.message || 'new commit';
      case 'push': return `pushed to ${d.branch || 'remote'}`;
      case 'pr_created': return `PR created: ${d.title || ''}`;
      case 'pr_merged': return `PR merged: ${d.title || ''}`;
      case 'budget_spend': return `$${(d.cost_usd || 0).toFixed(2)} — ${d.model || 'unknown'}`;
      case 'budget_alert': return `alert: ${d.level || 'warning'}`;
      case 'eval_job_queued': return `queued: ${d.model || ''} / ${d.task || ''}`;
      case 'eval_job_started': return `running: ${d.model || ''} / ${d.task || ''}`;
      case 'eval_job_completed': return `completed: ${d.model || ''} / ${d.task || ''}` + (d.accuracy != null ? ` (${(d.accuracy * 100).toFixed(1)}%)` : '');
      case 'eval_job_failed': return `failed: ${d.model || ''} / ${d.task || ''}` + (d.error ? ` — ${d.error}` : '');
      case 'daemon_start': return 'daemon started';
      case 'daemon_stop': return `daemon stopped (${d.cyclesCompleted || 0} cycles)`;
      case 'daemon_error': return d.error || 'daemon error';
      case 'phase_transition': return `${d.from || '?'} → ${d.to || '?'}`;
      default: return JSON.stringify(d).slice(0, 80);
    }
  }

  function getCategory(type) {
    return TYPE_CATEGORY[type] || 'system';
  }

  function getDotClass(ev) {
    if (ERROR_TYPES.has(ev.type)) return 'bg-red-400';
    return CATEGORY_COLORS[getCategory(ev.type)] || 'bg-[var(--color-text-muted)]';
  }

  function createEventRow(ev) {
    const cat = getCategory(ev.type);
    const row = document.createElement('div');
    row.className = 'event-row px-5 py-3 flex items-start gap-4';
    row.dataset.category = cat;

    if (activeFilter !== 'all' && cat !== activeFilter) {
      row.style.display = 'none';
    }

    row.innerHTML = `
      <div class="shrink-0 pt-1.5">
        <div class="w-1.5 h-1.5 rounded-full ${getDotClass(ev)}"></div>
      </div>
      <div class="min-w-0 flex-1">
        <div class="flex items-baseline gap-3 mb-0.5">
          <span class="font-mono text-[10px] uppercase tracking-wider text-[var(--color-text-muted)]">${formatType(ev.type)}</span>
          ${ev.project ? `<span class="font-mono text-[10px] px-1.5 bg-[var(--color-bg-surface)] text-[var(--color-text-muted)] border border-[var(--color-border)]">${ev.project}</span>` : ''}
        </div>
        <p class="font-mono text-xs text-[var(--color-text-secondary)] leading-snug">${summarize(ev)}</p>
      </div>
      <span class="shrink-0 font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums whitespace-nowrap pt-0.5">${formatTime(ev.timestamp)}</span>
    `;

    return row;
  }

  function renderAll() {
    feed.innerHTML = '';
    let visible = 0;
    for (const ev of events) {
      const row = createEventRow(ev);
      feed.appendChild(row);
      if (row.style.display !== 'none') visible++;
    }
    if (events.length === 0) {
      feed.innerHTML = '<div class="p-8 text-center"><p class="font-mono text-sm text-[var(--color-text-muted)]">No activity yet</p></div>';
    }
    updateCount(visible);
  }

  function prependEvent(ev) {
    if (emptyState && emptyState.parentNode === feed) {
      feed.removeChild(emptyState);
    }
    events.unshift(ev);
    if (events.length > MAX_EVENTS) events.pop();

    const row = createEventRow(ev);
    feed.insertBefore(row, feed.firstChild);

    // Trim DOM
    while (feed.children.length > MAX_EVENTS) {
      feed.removeChild(feed.lastChild);
    }

    updateVisibleCount();
  }

  function updateVisibleCount() {
    const visible = feed.querySelectorAll('.event-row:not([style*="display: none"])').length;
    updateCount(visible);
  }

  function updateCount(n) {
    eventCount.textContent = `${n} event${n !== 1 ? 's' : ''} shown` + (events.length > n ? ` (${events.length} total)` : '');
  }

  // ---- Connection status ----
  function setStatus(state) {
    connDot.className = 'w-2 h-2 rounded-full';
    if (state === 'connected') {
      connDot.classList.add('bg-emerald-400');
      connLabel.textContent = 'Connected';
    } else if (state === 'connecting') {
      connDot.classList.add('bg-amber-400');
      connLabel.textContent = 'Connecting…';
    } else {
      connDot.classList.add('bg-red-400');
      connLabel.textContent = 'Disconnected';
    }
  }

  // ---- Load initial data ----
  async function loadRecent() {
    try {
      const base = API_BASE || window.location.origin;
      const url = new URL('/api/activity/recent', base);
      url.searchParams.set('count', '50');
      if (API_KEY) url.searchParams.set('api_key', API_KEY);

      const res = await fetch(url.toString());
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const data = await res.json();

      // API returns oldest-first, we want newest-first
      events = data.reverse();
      renderAll();
    } catch (err) {
      console.error('Failed to load recent activity:', err);
      feed.innerHTML = `<div class="p-8 text-center"><p class="font-mono text-sm text-red-400">Failed to load: ${err.message}</p><p class="font-mono text-xs text-[var(--color-text-muted)] mt-2">Check API connection</p></div>`;
    }
  }

  // ---- WebSocket ----
  let ws = null;
  let reconnectDelay = 1000;
  const MAX_RECONNECT_DELAY = 30000;

  function connectWs() {
    setStatus('connecting');

    const wsProtocol = (API_BASE.startsWith('https') || window.location.protocol === 'https:') ? 'wss' : 'ws';
    const wsHost = API_BASE ? API_BASE.replace(/^https?:\/\//, '') : window.location.host;
    const wsUrl = `${wsProtocol}://${wsHost}/api/ws?api_key=${encodeURIComponent(API_KEY)}`;

    try {
      ws = new WebSocket(wsUrl);
    } catch {
      scheduleReconnect();
      return;
    }

    ws.onopen = () => {
      setStatus('connected');
      reconnectDelay = 1000;
      // Subscribe to logs channel
      ws.send(JSON.stringify({ type: 'subscribe', channel: 'logs' }));
    };

    ws.onmessage = (msg) => {
      try {
        const parsed = JSON.parse(msg.data);
        if (parsed.channel === 'logs' && parsed.data) {
          prependEvent(parsed.data);
        }
      } catch {
        // ignore malformed
      }
    };

    ws.onclose = () => {
      setStatus('disconnected');
      scheduleReconnect();
    };

    ws.onerror = () => {
      // onclose will fire after this
    };
  }

  function scheduleReconnect() {
    setTimeout(() => {
      reconnectDelay = Math.min(reconnectDelay * 2, MAX_RECONNECT_DELAY);
      connectWs();
    }, reconnectDelay);
  }

  // ---- Init ----
  loadRecent().then(() => {
    if (API_KEY) {
      connectWs();
    } else {
      setStatus('disconnected');
      connLabel.textContent = 'No API key';
    }
  });
</script>
