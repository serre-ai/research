---
import Breadcrumb from './Breadcrumb.astro';

interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: { label: string; href?: string }[];
  class?: string;
}

const { title, subtitle, breadcrumbs, class: className = '' } = Astro.props;
---

<section class:list={['max-w-6xl mx-auto px-6 pt-10 pb-6 relative', className]}>
  {breadcrumbs && <Breadcrumb items={breadcrumbs} />}
  <h1 class="text-2xl sm:text-3xl font-mono font-bold tracking-tight text-[var(--color-text-bright)] leading-[1.1]">
    {title}
  </h1>
  {subtitle && (
    <p class="text-sm text-[var(--color-text-muted)] mt-2 max-w-2xl">{subtitle}</p>
  )}
  <slot />
</section>
