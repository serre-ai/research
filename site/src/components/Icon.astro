---
import { readFileSync } from 'node:fs';
import { resolve } from 'node:path';

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 16, class: className = '' } = Astro.props;

// Read SVG from lucide-static at build time
const iconsDir = resolve('node_modules/lucide-static/icons');
let svgContent = '';
try {
  const raw = readFileSync(`${iconsDir}/${name}.svg`, 'utf-8');
  // Extract inner content (everything between <svg> tags)
  const inner = raw.replace(/<!--.*?-->\s*/g, '').replace(/<svg[^>]*>/, '').replace(/<\/svg>/, '').trim();
  svgContent = inner;
} catch {
  // Fallback: empty icon
}
---

<svg
  class:list={['icon', className]}
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  set:html={svgContent}
/>
