---
import Icon from './Icon.astro';

interface Props {
  message: string;
  detail?: string;
  icon?: string;
}

const { message, detail, icon } = Astro.props;
---

<div class="text-center py-16">
  {icon && (
    <div class="flex justify-center mb-4">
      <Icon name={icon} size={24} class="text-[var(--color-text-muted)]" />
    </div>
  )}
  <p class="font-mono text-sm text-[var(--color-text-muted)]">{message}</p>
  {detail && (
    <p class="text-xs text-[var(--color-text-muted)] mt-2">{detail}</p>
  )}
</div>
