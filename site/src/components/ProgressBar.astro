---
interface Props {
  value: number;
  label?: string;
  showPct?: boolean;
  color?: string;
  class?: string;
}

const { value, label, showPct = false, color = 'bg-emerald-500/60', class: className = '' } = Astro.props;
---

<div class:list={[className]}>
  {(label || showPct) && (
    <div class="flex justify-between font-mono text-xs mb-1.5">
      {label && <span class="text-[var(--color-text-muted)]">{label}</span>}
      {showPct && <span class="text-[var(--color-text-secondary)] tabular-nums">{value}%</span>}
    </div>
  )}
  <div class="h-1.5 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden">
    <div class={`h-full transition-all ${color}`} style={`width: ${value}%`}></div>
  </div>
</div>
