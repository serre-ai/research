---
interface Bar {
  label: string;
  value: number;
  color?: string;
}

interface Props {
  bars: Bar[];
  max?: number;
  height?: number;
  direction?: 'horizontal' | 'vertical';
  class?: string;
}

const { bars, max: maxOverride, height = 128, direction = 'vertical', class: className = '' } = Astro.props;

const colors = [
  'var(--color-data-1)',
  'var(--color-data-2)',
  'var(--color-data-3)',
  'var(--color-data-4)',
  'var(--color-data-5)',
  'var(--color-data-6)',
];

const maxValue = maxOverride ?? Math.max(...bars.map(b => b.value), 1);
---

{direction === 'vertical' ? (
  <div class:list={['flex items-end gap-1.5', className]} style={`height: ${height}px`}>
    {bars.map((bar, i) => {
      const pct = (bar.value / maxValue) * 100;
      const color = bar.color || colors[i % colors.length];
      return (
        <div class="flex-1 flex flex-col items-center gap-1">
          <span class="font-mono text-[9px] text-[var(--color-text-muted)] tabular-nums">{bar.value}</span>
          <div class="w-full" style={`height: ${pct}%; background: ${color}; opacity: 0.6;`}></div>
          <span class="font-mono text-[8px] text-[var(--color-text-muted)]">{bar.label}</span>
        </div>
      );
    })}
  </div>
) : (
  <div class:list={['flex flex-col gap-2', className]}>
    {bars.map((bar, i) => {
      const pct = (bar.value / maxValue) * 100;
      const color = bar.color || colors[i % colors.length];
      return (
        <div class="flex items-center gap-3">
          <span class="font-mono text-xs text-[var(--color-text-secondary)] w-20 shrink-0 truncate">{bar.label}</span>
          <div class="flex-1 h-4 bg-[var(--color-bg-surface)] border border-[var(--color-border)] overflow-hidden">
            <div class="h-full" style={`width: ${pct}%; background: ${color}; opacity: 0.5;`}></div>
          </div>
          <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums w-8 text-right shrink-0">{bar.value}</span>
        </div>
      );
    })}
  </div>
)}
