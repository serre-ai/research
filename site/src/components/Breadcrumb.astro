---
interface Props {
  items: { label: string; href?: string }[];
}

const { items } = Astro.props;
---

<nav class="flex items-center gap-2 mb-4">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="font-mono text-[10px] text-[var(--color-text-muted)]">/</span>}
      {item.href ? (
        <a href={item.href} class="font-mono text-[10px] text-[var(--color-text-muted)] hover:text-[var(--color-text-secondary)] transition-colors hover:no-underline">
          {item.label}
        </a>
      ) : (
        <span class="font-mono text-[10px] text-[var(--color-text-secondary)]">{item.label}</span>
      )}
    </>
  ))}
</nav>
