---
interface Props {
  value: string | number;
  label: string;
  sublabel?: string;
  color?: string;
  size?: 'sm' | 'md' | 'lg';
}

const { value, label, sublabel, color, size = 'md' } = Astro.props;

const sizeClasses = {
  sm: 'text-lg',
  md: 'text-2xl',
  lg: 'text-3xl',
};
---

<div>
  <p class="stat-label mb-2">{label}</p>
  <p class:list={[
    'font-mono font-bold tabular-nums',
    sizeClasses[size],
    color || 'text-[var(--color-text-bright)]',
  ]}>
    <slot name="value">{value}</slot>
  </p>
  {sublabel && (
    <p class="stat-label mt-1">{sublabel}</p>
  )}
</div>
