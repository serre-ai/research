---
import { healthDot, healthColor } from '../utils/helpers';

interface Props {
  status: string;
  label?: string;
}

const { status, label } = Astro.props;
---

<div class="flex items-center gap-2">
  <div class={`w-1.5 h-1.5 rounded-full ${healthDot(status)}`}></div>
  {label && (
    <span class={`font-mono text-xs ${healthColor(status)}`}>{label}</span>
  )}
</div>
