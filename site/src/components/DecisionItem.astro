---
interface Props {
  date: string;
  decision: string;
  rationale: string;
  project?: string;
  projectHref?: string;
}

const { date, decision, rationale, project, projectHref } = Astro.props;
---

<div class="py-4 first:pt-0 last:pb-0">
  <div class="flex items-start gap-4">
    <div class="shrink-0 pt-0.5">
      <span class="font-mono text-[10px] text-[var(--color-text-muted)] tabular-nums whitespace-nowrap">{date}</span>
    </div>
    <div class="min-w-0 flex-1">
      {project && (
        <div class="flex items-center gap-2 mb-0.5">
          {projectHref ? (
            <a href={projectHref} class="font-mono text-[10px] px-1.5 py-0 bg-[var(--color-bg-surface)] text-[var(--color-text-muted)] border border-[var(--color-border)] hover:text-[var(--color-text-secondary)] hover:no-underline transition-colors">
              {project}
            </a>
          ) : (
            <span class="font-mono text-[10px] px-1.5 py-0 bg-[var(--color-bg-surface)] text-[var(--color-text-muted)] border border-[var(--color-border)]">
              {project}
            </span>
          )}
        </div>
      )}
      <p class="font-mono text-sm text-[var(--color-text-bright)] leading-snug">{decision}</p>
      <p class="text-xs text-[var(--color-text-muted)] mt-1.5 leading-relaxed">{rationale}</p>
    </div>
  </div>
</div>
