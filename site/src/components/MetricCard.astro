---
import Icon from './Icon.astro';

interface Props {
  label: string;
  value: string | number;
  sublabel?: string;
  icon?: string;
  color?: string;
}

const { label, value, sublabel, icon, color } = Astro.props;
---

<div class="border border-[var(--color-border)] bg-[var(--color-bg-elevated)] p-5">
  <div class="flex items-start justify-between mb-2">
    <p class="stat-label">{label}</p>
    {icon && <Icon name={icon} size={14} class="text-[var(--color-text-muted)]" />}
  </div>
  <p class:list={[
    'font-mono text-3xl font-bold tabular-nums',
    color || 'text-[var(--color-text-bright)]',
  ]}>
    <slot name="value">{value}</slot>
  </p>
  {sublabel && (
    <p class="stat-label mt-1">{sublabel}</p>
  )}
</div>
