0:{"rsc":["$","$1","c",{"children":[[["$","section",null,{"className":"pt-8 pb-4","children":[["$","h1",null,{"className":"text-xs text-text-muted uppercase tracking-widest mb-8","children":"About"}],["$","div",null,{"className":"space-y-6 text-sm leading-relaxed","children":[["$","p",null,{"children":[["$","span",null,{"className":"text-text-bright","children":"Serre AI"}]," is an independent research lab focused on the formal foundations of AI reasoning. We prove theorems about what language models can and cannot do."]}],["$","p",null,{"children":"Our work spans three areas: the computational complexity of LLM reasoning, the theory of verifying model outputs, and empirical evaluation at scale. We publish at top venues and release our benchmarks, data, and analysis code."}]]}]]}],["$","hr",null,{}],["$","section",null,{"children":[["$","h2",null,{"className":"text-xs text-text-muted uppercase tracking-widest mb-6","children":"Researcher"}],["$","div",null,{"className":"text-sm space-y-2","children":[["$","p",null,{"className":"text-text-bright","children":"Oddur Sigurdsson"}],["$","p",null,{"children":"Based in Reykjavik. Background in software engineering and computational theory. Building Serre AI as a solo research operation with autonomous infrastructure."}],["$","p",null,{"className":"text-text-muted mt-4","children":"oddur@serre.ai"}]]}]]}],["$","hr",null,{}],["$","section",null,{"children":[["$","h2",null,{"className":"text-xs text-text-muted uppercase tracking-widest mb-6","children":"Methodology"}],["$","div",null,{"className":"text-sm space-y-4 leading-relaxed","children":[["$","p",null,{"children":"We run research using autonomous AI agents built on Claude Code. Our platform orchestrates literature surveys, experiment design and execution, paper drafting, and internal peer review — all as structured agent sessions with quality gates, budget controls, and formal verification."}],["$","p",null,{"children":"This isn't AI-assisted writing. The agents operate autonomously within defined research protocols: pre-registered experiments, knowledge graph consistency checks, and multi-agent review cycles. Human oversight is strategic, not operational."}],["$","p",null,{"children":"The platform itself — an autonomous research orchestrator — is a research artifact. We study what works and what breaks when AI agents do science."}]]}]]}],["$","hr",null,{}],["$","section",null,{"children":[["$","h2",null,{"className":"text-xs text-text-muted uppercase tracking-widest mb-6","children":"Research Areas"}],["$","div",null,{"className":"text-sm space-y-6","children":[["$","div",null,{"children":[["$","p",null,{"className":"text-text-bright","children":"Computational Complexity of LLM Reasoning"}],["$","p",null,{"className":"mt-1","children":"Formal characterization of when and why language models fail at reasoning tasks, mapped to complexity classes. What is the relationship between a task's computational difficulty and a model's accuracy?"}]]}],["$","div",null,{"children":[["$","p",null,{"className":"text-text-bright","children":"Verification Theory"}],["$","p",null,{"className":"mt-1","children":"When can we efficiently check whether a model's output is correct? Complexity-theoretic bounds on verification, with applications to scalable oversight and cross-model consistency."}]]}],["$","div",null,{"children":[["$","p",null,{"className":"text-text-bright","children":"Benchmark Design"}],["$","p",null,{"className":"mt-1","children":"Building evaluation frameworks with known computational structure. Tasks with provable ground truth, controlled difficulty scaling, and formal guarantees about what they measure."}]]}]]}]]}]],null,["$","$L2",null,{"children":["$","$3",null,{"name":"Next.MetadataOutlet","children":"$@4"}]}]]}],"isPartial":false,"staleTime":300,"varyParams":null,"buildId":"rnLt3tMoMWiOuArlf3qRp"}
