\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Self-Consistency Scaling (Experiment~1)}{9}{subsection.6.2}\protected@file@percent }
\newlabel{sec:exp_scaling}{{6.2}{9}{Self-Consistency Scaling (Experiment~1)}{subsection.6.2}{}}
\newlabel{sec:exp_scaling@cref}{{[subsection][2][6]6.2}{[1][9][]9}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Self-consistency scaling curves with theoretical predictions. Accuracy vs.\ sample count $N$ for three tasks spanning the bottleneck spectrum, across three model families. Solid lines: empirical accuracy with 95\% bootstrap confidence intervals. Dashed lines: zero-parameter theoretical prediction using $N_{\text  {eff}} = N/(1 + (N-1)\rho )$ with externally measured $\rho $. The theoretical curve predicts not just the existence of plateaus but their location: B6 ($\rho = 0.42$) saturates by $N \approx 5$, while B7 ($\rho = 0.06$) continues improving past $N = 33$.}}{10}{figure.caption.18}\protected@file@percent }
\newlabel{fig:scaling}{{1}{10}{Self-consistency scaling curves with theoretical predictions. Accuracy vs.\ sample count $N$ for three tasks spanning the bottleneck spectrum, across three model families. Solid lines: empirical accuracy with 95\% bootstrap confidence intervals. Dashed lines: zero-parameter theoretical prediction using $N_{\text {eff}} = N/(1 + (N-1)\rho )$ with externally measured $\rho $. The theoretical curve predicts not just the existence of plateaus but their location: B6 ($\rho = 0.42$) saturates by $N \approx 5$, while B7 ($\rho = 0.06$) continues improving past $N = 33$}{figure.caption.18}{}}
\newlabel{fig:scaling@cref}{{[figure][1][]1}{[1][9][]10}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Self-consistency results summary. Acc@$N$ is majority-vote accuracy over $N$ samples. Lift = Acc@33 $-$ Acc@1. $\rho _{\text  {within}}$ is measured from $N = 33$ samples via ICC; $\rho _{\text  {between}}$ is from the external companion evaluation (used in the zero-parameter prediction). Predicted $N_{\text  {eff}}$ limit $= 1/\rho _{\text  {between}}$. Observed plateau $N$ is the smallest $N$ where accuracy improvement drops below 2 pp per doubling. Results pending; dashes indicate placeholders.}}{10}{table.caption.19}\protected@file@percent }
\newlabel{tab:results}{{2}{10}{Self-consistency results summary. Acc@$N$ is majority-vote accuracy over $N$ samples. Lift = Acc@33 $-$ Acc@1. $\rho _{\text {within}}$ is measured from $N = 33$ samples via ICC; $\rho _{\text {between}}$ is from the external companion evaluation (used in the zero-parameter prediction). Predicted $N_{\text {eff}}$ limit $= 1/\rho _{\text {between}}$. Observed plateau $N$ is the smallest $N$ where accuracy improvement drops below 2 pp per doubling. Results pending; dashes indicate placeholders}{table.caption.19}{}}
\newlabel{tab:results@cref}{{[table][2][]2}{[1][9][]10}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}Error Correlation Structure (Experiment~2)}{10}{subsection.6.3}\protected@file@percent }
\newlabel{sec:exp_correlation}{{6.3}{10}{Error Correlation Structure (Experiment~2)}{subsection.6.3}{}}
\newlabel{sec:exp_correlation@cref}{{[subsection][3][6]6.3}{[1][9][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Error correlation by task and verification complexity class. Within-model $\rho $ (bars) measured from $N = 33$ within-model samples via intraclass correlation. Horizontal markers show external between-model $\rho $ from the companion evaluation. The non-monotonicity prediction: B6 ($\mathrm  {VC}= \mathrm  {P}$, shared bottleneck) has higher $\rho $ than B7 ($\mathrm  {VC}\supseteq \mathrm  {coNP}$, stochastic bottleneck). Easier verification class, higher error correlation.}}{11}{figure.caption.20}\protected@file@percent }
\newlabel{fig:correlation}{{2}{11}{Error correlation by task and verification complexity class. Within-model $\rho $ (bars) measured from $N = 33$ within-model samples via intraclass correlation. Horizontal markers show external between-model $\rho $ from the companion evaluation. The non-monotonicity prediction: B6 ($\VC = \PTIME $, shared bottleneck) has higher $\rho $ than B7 ($\VC \supseteq \coNP $, stochastic bottleneck). Easier verification class, higher error correlation}{figure.caption.20}{}}
\newlabel{fig:correlation@cref}{{[figure][2][]2}{[1][10][]11}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Within-model vs.\ between-model ensemble accuracy at $N = 9$. Within-model: majority vote of 9 samples from Haiku at $T = 1.0$. Between-model: majority vote of 9 models (sampled from 11 available) from the companion evaluation. On shared-bottleneck tasks (B6), between-model ensembles substantially outperform within-model SC because diverse models fail on different instances. On stochastic-bottleneck tasks (B7), the gap narrows.}}{11}{figure.caption.21}\protected@file@percent }
\newlabel{fig:ensemble}{{3}{11}{Within-model vs.\ between-model ensemble accuracy at $N = 9$. Within-model: majority vote of 9 samples from Haiku at $T = 1.0$. Between-model: majority vote of 9 models (sampled from 11 available) from the companion evaluation. On shared-bottleneck tasks (B6), between-model ensembles substantially outperform within-model SC because diverse models fail on different instances. On stochastic-bottleneck tasks (B7), the gap narrows}{figure.caption.21}{}}
\newlabel{fig:ensemble@cref}{{[figure][3][]3}{[1][11][]11}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.4}Within-Model vs.\ Between-Model Ensembles (Experiment~3)}{11}{subsection.6.4}\protected@file@percent }
\newlabel{sec:exp_ensemble}{{6.4}{11}{Within-Model vs.\ Between-Model Ensembles (Experiment~3)}{subsection.6.4}{}}
