\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Cross-model verification accuracy by task and $\mathrm  {VC}$ class. Each bar represents the fraction of instances where a verifier model correctly classifies a generator's output as correct or incorrect. Canary run: B4 ($\mathrm  {VC}= \mathrm  {P}$) achieves 100\% verification accuracy; B7 ($\mathrm  {VC}\supseteq \mathrm  {coNP}$) achieves only 64\%, consistent with \Cref  {thm:advantage}: verification succeeds when $\mathrm  {VC}(\mathcal  {F}) \subseteq \mathrm  {cap}(\mathcal  {M})$ and fails when it does not.}}{12}{figure.caption.22}\protected@file@percent }
\newlabel{fig:verification}{{4}{12}{Cross-model verification accuracy by task and $\VC $ class. Each bar represents the fraction of instances where a verifier model correctly classifies a generator's output as correct or incorrect. Canary run: B4 ($\VC = \PTIME $) achieves 100\% verification accuracy; B7 ($\VC \supseteq \coNP $) achieves only 64\%, consistent with \Cref {thm:advantage}: verification succeeds when $\VC (\calF ) \subseteq \mathrm {cap}(\calM )$ and fails when it does not}{figure.caption.22}{}}
\newlabel{fig:verification@cref}{{[figure][4][]4}{[1][12][]12}{}{}{}}
