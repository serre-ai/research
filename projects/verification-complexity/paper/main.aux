\@writefile{toc}{\contentsline {subsection}{\numberline {6.2}Within-Model Self-Consistency is Universally Bounded}{9}{subsection.6.2}\protected@file@percent }
\newlabel{sec:exp_scaling}{{6.2}{9}{Within-Model Self-Consistency is Universally Bounded}{subsection.6.2}{}}
\newlabel{sec:exp_scaling@cref}{{[subsection][2][6]6.2}{[1][9][]9}{}{}{}}
\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Phase~1 self-consistency results (Haiku, $T = 1.0$, 200 instances per task). Acc@$N$ is majority-vote accuracy over $N$ samples. Lift = Acc@33 $-$ Acc@1. $\rho _{\text  {within}}$ is measured from $N = 33$ samples via ICC; $\rho _{\text  {between}}$ is from the external companion evaluation. The key observation: $\rho _{\text  {within}}$ is uniformly high (0.28--0.54) and does not track $\rho _{\text  {between}}$, explaining why SC lift is universally small. Predicted $N_{\text  {eff}}(\rho _{\text  {within}})$ is computed using $\rho _{\text  {within}}$ at $N = 33$.}}{10}{table.caption.17}\protected@file@percent }
\newlabel{tab:results}{{2}{10}{Phase~1 self-consistency results (Haiku, $T = 1.0$, 200 instances per task). Acc@$N$ is majority-vote accuracy over $N$ samples. Lift = Acc@33 $-$ Acc@1. $\rho _{\text {within}}$ is measured from $N = 33$ samples via ICC; $\rho _{\text {between}}$ is from the external companion evaluation. The key observation: $\rho _{\text {within}}$ is uniformly high (0.28--0.54) and does not track $\rho _{\text {between}}$, explaining why SC lift is universally small. Predicted $N_{\text {eff}}(\rho _{\text {within}})$ is computed using $\rho _{\text {within}}$ at $N = 33$}{table.caption.17}{}}
\newlabel{tab:results@cref}{{[table][2][]2}{[1][10][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Error correlation by task: within-model $\rho $ (measured from $N = 33$ samples via ICC, with 95\% CIs) vs.\ between-model $\rho $ (from the companion 12-model evaluation). Within-model $\rho $ is uniformly high (0.28--0.54) with no significant task variation: B6 and B7 are statistically indistinguishable ($\Delta = 0.013$, $p = 0.39$). Between-model $\rho $ varies by an order of magnitude (0.06--0.42) and tracks bottleneck type. The gap $\rho _{\text  {within}} - \rho _{\text  {between}}$ is itself informative: largest for B7 (stochastic bottleneck, $\Delta = 0.47$), smallest for B6 (shared bottleneck, $\Delta = 0.12$).}}{10}{figure.caption.18}\protected@file@percent }
\newlabel{fig:correlation}{{2}{10}{Error correlation by task: within-model $\rho $ (measured from $N = 33$ samples via ICC, with 95\% CIs) vs.\ between-model $\rho $ (from the companion 12-model evaluation). Within-model $\rho $ is uniformly high (0.28--0.54) with no significant task variation: B6 and B7 are statistically indistinguishable ($\Delta = 0.013$, $p = 0.39$). Between-model $\rho $ varies by an order of magnitude (0.06--0.42) and tracks bottleneck type. The gap $\rho _{\text {within}} - \rho _{\text {between}}$ is itself informative: largest for B7 (stochastic bottleneck, $\Delta = 0.47$), smallest for B6 (shared bottleneck, $\Delta = 0.12$)}{figure.caption.18}{}}
\newlabel{fig:correlation@cref}{{[figure][2][]2}{[1][10][]10}{}{}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.3}The Architectural Barrier: Within- vs.\ Between-Model Correlation}{10}{subsection.6.3}\protected@file@percent }
\newlabel{sec:exp_correlation}{{6.3}{10}{The Architectural Barrier: Within- vs.\ Between-Model Correlation}{subsection.6.3}{}}
\newlabel{sec:exp_correlation@cref}{{[subsection][3][6]6.3}{[1][10][]10}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Quality-matched between-model ensemble vs.\ within-model SC, evaluated on common instance sets. For B7 (stochastic bottleneck), quality-matched between-model ensembles outperform within-model SC by 2.6 pp at $N = 3$ and 4.1 pp at $N = 5$, consistent with the prediction that model diversity unlocks improvement when $\rho _{\text  {between}} \ll \rho _{\text  {within}}$. For B6 (shared bottleneck) and B4, no meaningful difference: the shared bottleneck persists across models. Models selected within $\pm $10 pp of Haiku's accuracy per task; between-model accuracy averaged over all $\binom  {k}{N}$ subsets.}}{11}{figure.caption.19}\protected@file@percent }
\newlabel{fig:ensemble}{{3}{11}{Quality-matched between-model ensemble vs.\ within-model SC, evaluated on common instance sets. For B7 (stochastic bottleneck), quality-matched between-model ensembles outperform within-model SC by 2.6 pp at $N = 3$ and 4.1 pp at $N = 5$, consistent with the prediction that model diversity unlocks improvement when $\rho _{\text {between}} \ll \rho _{\text {within}}$. For B6 (shared bottleneck) and B4, no meaningful difference: the shared bottleneck persists across models. Models selected within $\pm $10 pp of Haiku's accuracy per task; between-model accuracy averaged over all $\binom {k}{N}$ subsets}{figure.caption.19}{}}
\newlabel{fig:ensemble@cref}{{[figure][3][]3}{[1][11][]11}{}{}{}}
