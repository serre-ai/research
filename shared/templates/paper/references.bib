% ==============================================================================
% BibTeX references — Deepwork Research Platform
%
% Conventions:
%   - Key format: AuthorYear or AuthorYearKeyword (e.g., Vaswani2017, Brown2020GPT3)
%   - Always use full first names when available
%   - Use published venue version over arxiv when both exist
%   - Include DOI or URL for all entries
%   - Keep entries sorted alphabetically by key
%
% See shared/standards/citation-style.md for full citation policy.
% ==============================================================================

% --- Example: Conference paper ---
@inproceedings{Vaswani2017,
  title     = {Attention Is All You Need},
  author    = {Vaswani, Ashish and Shazeer, Noam and Parmar, Niki and Uszkoreit, Jakob and Jones, Llion and Gomez, Aidan N and Kaiser, {\L}ukasz and Polosukhin, Illia},
  booktitle = {Advances in Neural Information Processing Systems},
  volume    = {30},
  year      = {2017},
  url       = {https://proceedings.neurips.cc/paper/2017/hash/3f5ee243547dee91fbd053c1c4a845aa-Abstract.html},
}

% --- Example: Journal article ---
@article{Hochreiter1997,
  title     = {Long Short-Term Memory},
  author    = {Hochreiter, Sepp and Schmidhuber, J{\"u}rgen},
  journal   = {Neural Computation},
  volume    = {9},
  number    = {8},
  pages     = {1735--1780},
  year      = {1997},
  publisher = {MIT Press},
  doi       = {10.1162/neco.1997.9.8.1735},
}

% --- Example: Arxiv preprint ---
@misc{Wei2022ChainOfThought,
  title         = {Chain-of-Thought Prompting Elicits Reasoning in Large Language Models},
  author        = {Wei, Jason and Wang, Xuezhi and Schuurmans, Dale and Bosma, Maarten and Ichter, Brian and Xia, Fei and Chi, Ed and Le, Quoc V and Zhou, Denny},
  year          = {2022},
  eprint        = {2201.11903},
  archiveprefix = {arXiv},
  primaryclass  = {cs.CL},
  url           = {https://arxiv.org/abs/2201.11903},
}

% --- Example: Book / Book chapter ---
@incollection{Goodfellow2016,
  title     = {Deep Learning},
  author    = {Goodfellow, Ian and Bengio, Yoshua and Courville, Aaron},
  booktitle = {Deep Learning},
  chapter   = {10},
  pages     = {363--400},
  publisher = {MIT Press},
  year      = {2016},
  url       = {https://www.deeplearningbook.org/},
}
