# Deepwork Platform Configuration
# Copy to .env and fill in your values

# Anthropic API (required — for Claude Agent SDK sessions)
ANTHROPIC_API_KEY=sk-ant-...

# Modal (optional — GPU compute via modal.com)
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Notifications (optional — Slack/Discord webhook URL)
NOTIFICATION_WEBHOOK_URL=

# Daemon settings
DAILY_BUDGET_USD=40
MAX_CONCURRENT_SESSIONS=2
POLL_INTERVAL_MINUTES=30
