{
  "name": "@serre/orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node dist/migrate.js",
    "migrate:baseline": "node dist/migrate.js --baseline",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "backfill-embeddings": "node dist/backfill-embeddings.js"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.77",
    "express": "^4.21.0",
    "pg": "^8.13.0",
    "ws": "^8.18.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.1"
  }
}
